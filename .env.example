# ── GDrive Sync API — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in real values.
# Load with: python-dotenv, or set in your shell / Docker / Windows service.

# ── Paths ─────────────────────────────────────────────────────────────────────
RCLONE_EXE=C:\ProgramData\chocolatey\lib\rclone.portable\tools\rclone-v1.73.2-windows-amd64\rclone.exe
LOG_FILE=C:\Python314\Scripts\customScript\gdrive_sync.log
STATE_FILE=C:\Python314\Scripts\customScript\gdrive_sync_state.json

# ── Upload tuning ─────────────────────────────────────────────────────────────
MAX_UPLOAD_WORKERS=3
SETTLE_SECONDS=30
DIALOG_TIMEOUT=60
LOG_MAX_MB=5
LOG_BACKUPS=3

# ── API Auth ──────────────────────────────────────────────────────────────────
# CRITICAL: change JWT_SECRET to a long random string in production!
JWT_SECRET=changeme-use-a-long-random-secret
JWT_EXPIRE_MINUTES=60

# ── CORS (comma-separated list of allowed dashboard origins) ──────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
